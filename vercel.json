{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/auth/(.*)", "dest": "/api/index.php?path=auth/$1" },
    { "src": "/user/(.*)", "dest": "/api/index.php?path=user/$1" },
    { "src": "/transaction/(.*)", "dest": "/api/index.php?path=transaction/$1" },
    { "src": "/category/(.*)", "dest": "/api/index.php?path=category/$1" },
    { "src": "/dashboard/(.*)", "dest": "/api/index.php?path=dashboard/$1" },
    { "src": "/(.*)", "dest": "/api/index.php?path=$1" }
  ]
}